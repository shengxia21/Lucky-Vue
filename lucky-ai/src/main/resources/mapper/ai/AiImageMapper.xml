<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lucky.ai.mapper.AiImageMapper">

    <resultMap type="AiImage" id="AiImageResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="prompt"    column="prompt"    />
        <result property="platform"    column="platform"    />
        <result property="modelId"    column="model_id"    />
        <result property="model"    column="model"    />
        <result property="width"    column="width"    />
        <result property="height"    column="height"    />
        <result property="status"    column="status"    />
        <result property="finishTime"    column="finish_time"    />
        <result property="errorMessage"    column="error_message"    />
        <result property="picUrl"    column="pic_url"    />
        <result property="publicStatus"    column="public_status"    />
        <result property="options"    column="options"    />
        <result property="taskId"    column="task_id"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAiImageVo">
        select id, user_id, prompt, platform, model_id, model, width, height, status, finish_time, error_message, pic_url, public_status, options, task_id, del_flag, create_by, create_time, update_by, update_time from ai_image
    </sql>

    <select id="selectPageMy" parameterType="com.lucky.ai.controller.image.vo.AiImagePageReqVO" resultMap="AiImageResult">
        <include refid="selectAiImageVo"/>
        <where>
            <if test="prompt != null and prompt != ''">
                AND prompt LIKE CONCAT('%', #{prompt}, '%')
            </if>
            <if test="publicStatus != null and publicStatus == true">
                AND public_status = #{publicStatus}
            </if>
            <if test="publicStatus != null and publicStatus == false">
                AND user_id = #{userId}
            </if>
            AND del_flag = 0
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectPage" parameterType="com.lucky.ai.controller.image.vo.AiImagePublicPageReqVO" resultMap="AiImageResult">
        <include refid="selectAiImageVo"/>
        <where>
            <if test="prompt != null and prompt != ''">
                AND prompt LIKE CONCAT('%', #{prompt}, '%')
            </if>
            AND public_status = true
            AND del_flag = 0
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectAiImageById" parameterType="Long" resultMap="AiImageResult">
        <include refid="selectAiImageVo"/>
        where id = #{id}
        and del_flag = 0
    </select>

    <select id="selectByIds" parameterType="List" resultMap="AiImageResult">
        <include refid="selectAiImageVo"/>
        where id in
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
        and del_flag = 0
    </select>

    <select id="selectAiImagePage" parameterType="com.lucky.ai.controller.image.vo.AiImagePageReqVO" resultMap="AiImageResult">
        <include refid="selectAiImageVo"/>
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="platform != null and platform != ''">
                AND platform = #{platform}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="publicStatus != null">
                AND public_status = #{publicStatus}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
            AND del_flag = 0
        </where>
        ORDER BY id DESC
    </select>

    <insert id="insertAiImage" parameterType="AiImage" useGeneratedKeys="true" keyProperty="id">
        insert into ai_image
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="prompt != null and prompt != ''">prompt,</if>
            <if test="platform != null and platform != ''">platform,</if>
            <if test="modelId != null">model_id,</if>
            <if test="model != null and model != ''">model,</if>
            <if test="width != null">width,</if>
            <if test="height != null">height,</if>
            <if test="status != null">status,</if>
            <if test="finishTime != null">finish_time,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="picUrl != null">pic_url,</if>
            <if test="publicStatus != null">public_status,</if>
            <if test="options != null">options,</if>
            <if test="taskId != null">task_id,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="prompt != null and prompt != ''">#{prompt},</if>
            <if test="platform != null and platform != ''">#{platform},</if>
            <if test="modelId != null">#{modelId},</if>
            <if test="model != null and model != ''">#{model},</if>
            <if test="width != null">#{width},</if>
            <if test="height != null">#{height},</if>
            <if test="status != null">#{status},</if>
            <if test="finishTime != null">#{finishTime},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="picUrl != null">#{picUrl},</if>
            <if test="publicStatus != null">#{publicStatus},</if>
            <if test="options != null">#{options},</if>
            <if test="taskId != null">#{taskId},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateAiImage" parameterType="AiImage">
        update ai_image
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="prompt != null and prompt != ''">prompt = #{prompt},</if>
            <if test="platform != null and platform != ''">platform = #{platform},</if>
            <if test="modelId != null">model_id = #{modelId},</if>
            <if test="model != null and model != ''">model = #{model},</if>
            <if test="width != null">width = #{width},</if>
            <if test="height != null">height = #{height},</if>
            <if test="status != null">status = #{status},</if>
            <if test="finishTime != null">finish_time = #{finishTime},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="picUrl != null">pic_url = #{picUrl},</if>
            <if test="publicStatus != null">public_status = #{publicStatus},</if>
            <if test="options != null">options = #{options},</if>
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
        and del_flag = 0
    </update>

    <update id="deleteAiImageById" parameterType="Long">
        update ai_image set del_flag = 1 where id = #{id}
    </update>

</mapper>